{
  "variants": {
    "01-giardia-neighbor-fear": {
      "headline": "O cachorro da minha vizinha morreu com seis anos",
      "lead": "Quando soube o motivo, entrei em casa e olhei a gengiva do Thor. Foi numa terça de manhã. A Sandra me contou por cima do muro. O Bailey dela. O cachorro mais docil da rua. Sempre na veterinária. Sempre tomando remédio. Sempre tomando vermífugo a cada poucos meses, religiosamente.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/01-giardia-neighbor-fear/hero.jpg"
    },
    "02-bloody-diarrhea-midnight": {
      "headline": "Acordei às 3 da manhã e tinha sangue no chão",
      "lead": "Acordei às três da manhã com um barulho na cozinha. Acendi a luz. Não era muito. Mas era sangue. Vinha do cocô da minha Frida. Meu coração disparou. Ela me olhou com cara de culpa. Tremendo. A barriga fazendo barulho. Limpei o chão chorando.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/02-bloody-diarrhea-midnight/hero.jpg"
    },
    "03-senior-just-old": {
      "headline": "Eu achei que ele estava só ficando velho",
      "lead": "Eu achei que o Rex estava só ficando velho. Ele estava ficando doente. E eu não vi. O Rex tem doze anos. Labrador grande. Sempre foi o rei da casa. Há uns meses, ele mudou. Comia metade da ração. Depois nem isso. O cocô ficou mole. Às vezes líquido.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/03-senior-just-old/hero.jpg"
    },
    "04-gland-abscess-discovery": {
      "headline": "Nunca ouvi falar em glândula anal até a da minha cadela estourar",
      "lead": "Eu nunca tinha ouvido falar em glândula anal até a da minha Lola estourar. Foi de noite. Apareceu um caroço perto do bumbum dela. No dia seguinte, abriu. Sangue e pus. Ela chorando de dor. Corri pro veterinário de emergência. Ele limpou, passou antibiótico e disse que isso podia voltar.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/04-gland-abscess-discovery/hero.jpg"
    },
    "05-chronic-vomiting-stat": {
      "headline": "Minha cachorra vomitava quase todo dia. Eu pensei no pior",
      "lead": "Um cachorro pode vomitar uma vez e não ser nada. Mas quando li que a maioria dos casos de vômito que volta toda semana começa no intestino, e não no estômago, eu parei tudo. Porque a minha Aza vomitava quase todo dia.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/05-chronic-vomiting-stat/hero.jpg"
    },
    "01-itching-gut-skin": {
      "headline": "Gastei mais de R$ 2.400 tentando parar a coceira do meu cão",
      "lead": "Gastei mais de R$ 2.400 em um ano tentando parar a coceira do Fred. Shampoo medicado. Corticoide. Antibiótico. Colar elizabétano. Ração hipoalergênica a R$ 280 o saco. A coceira sempre voltava. Eu achava que o problema era a pele.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/01-itching-gut-skin/hero.jpg"
    },
    "02-anal-gland-fiber": {
      "headline": "Eu achava que arrastar o bumbum era 'coisa de cachorro'",
      "lead": "A maioria dos donos acha que arrastar o bumbum é \"coisa de cachorro.\" Não é. É um sinal de que a glândula não está esvaziando. E o motivo é simples. Deixa eu te explicar do jeito que finalmente entendi.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/02-anal-gland-fiber/hero.jpg"
    },
    "03-yucca-giardia-hidden": {
      "headline": "Tem um motivo pro vermífugo sempre falhar. Quase ninguém conta",
      "lead": "Tem um motivo pra você dar vermífugo e o problema voltar em poucas semanas. E quase ninguém te conta. O vermífugo comum mata os parasitas adultos. Só os adultos. Mas o problema não são só os adultos. São os ovos e as larvas que ficam no intestino.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/03-yucca-giardia-hidden/hero.jpg"
    },
    "04-prebiotic-vs-probiotic-insider": {
      "headline": "Trabalho num pet shop e vou contar uma coisa que vendemos errado",
      "lead": "Trabalho num pet shop e vou contar uma coisa que a gente vende errado o tempo todo. A maioria dos donos compra probiótico achando que vai resolver a barriga do cachorro. E muita gente não vê resultado. Tem um motivo.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/04-prebiotic-vs-probiotic-insider/hero.jpg"
    },
    "05-ginger-grass-eating-discovery": {
      "headline": "Eu achava engraçado meu cão comer grama. Até descobrir o que era",
      "lead": "Eu sempre achei engraçado o meu cachorro comer grama. Até descobrir o que isso queria dizer. O Tom comia grama feito louco. Quase com desespero. Depois vomitava no tapete. Eu achava que era só mania.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/05-ginger-grass-eating-discovery/hero.jpg"
    },
    "01-anal-glands-vet-cycle": {
      "headline": "Eu levava minha cadela na vet toda semana. Estava piorando tudo",
      "lead": "PARE de levar seu cachorro na veterinária todo mês para esvaziar a glândula anal. Sei que parece loucura. Mas cada vez que fazem isso, o problema piora. Deixa eu explicar. Eu fazia a mesma coisa. A cada três semanas, como relógio.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/01-anal-glands-vet-cycle/hero.jpg"
    },
    "02-probiotic-only-myth": {
      "headline": "Todo mundo me dizia que probiótico ia resolver. Não resolveu",
      "lead": "Todo mundo me dizia que probiótico ia resolver a barriga da minha cachorra. Funcionou. Mais ou menos. Por uns dias. Depois voltou tudo. A minha Pérola é uma Yorkie pequena. Quatro anos. Uns três quilos. Cocô mole há meses. Gases. Barriga roncando alto. Parecia desconfortável o tempo todo.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/02-probiotic-only-myth/hero.jpg"
    },
    "03-pumpkin-myth-hidden": {
      "headline": "'É só dar abóbora.' Eu ouvi isso de todo mundo",
      "lead": "\"É só dar abóbora.\" Eu ouvi isso de todo mundo. Quase ninguém te conta por que isso quase nunca funciona de verdade. O meu Tonico, um Beagle, vivia com cocô mole. Comprei abóbora em lata. Misturei na comida. Ele comeu em volta e deixou o resto.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/03-pumpkin-myth-hidden/hero.jpg"
    },
    "04-poop-eating-training-myth": {
      "headline": "Eu gritei com o meu cachorro por um ano inteiro. E eu estava errada",
      "lead": "Eu gritei com o meu cachorro por um ano inteiro por causa disso. E eu estava errada. O Theo comia cocô em todo passeio. O dele, de outros cães, qualquer um. Todo mundo dizia que era falta de adestramento. \"Ele é mal treinado.\" \"Falta pulso firme.\"",
      "hero": "https://artigos.mimiepipo.com.br/creatives/04-poop-eating-training-myth/hero.jpg"
    },
    "01-coprophagia-walk": {
      "headline": "Eu tinha vergonha até de falar sobre isso",
      "lead": "O Bob comia cocô em todo passeio. Todo. Single. Passeio. Não importava se era dele ou de outro cachorro. Se eu virava duas segundos, ele corria. Gritava. Puxava a guia. Oferecia petisco melhor. Nada funcionava. Uma vez ele comeu antes de eu puxar. Lambia a boca olhando pra mim.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/01-coprophagia-walk/hero.jpg"
    },
    "02-fishy-smell-friend-noticed": {
      "headline": "Uma amiga sentiu o cheiro antes de mim. Eu queria sumir",
      "lead": "Ela sentou no meu sofá. Fez uma carinha. Perguntou baixinho: \"Que cheiro é esse? Tipo peixe?\" Era o Tito. Meu French Bulldog. Eu já tinha sentido. Mas como moro com ele, achei que tinha me acostumado. Quando outra pessoa sentiu, a vergonha bateu forte. Parecia que minha casa era suja.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/02-fishy-smell-friend-noticed/hero.jpg"
    },
    "03-apartment-odor-insider": {
      "headline": "A tosadora me disse uma coisa que nenhum veterinário tinha falado",
      "lead": "Moro num apartamento pequeno com a Meg, minha Pug. O cocô dela tinha um cheiro horrível. Forte demais pro tamanho dela. Num apartamento pequeno, esse cheiro toma tudo. Eu vivia com vela acesa e spray na mão. Tinha vergonha quando alguém entrava. Até no elevador eu achava que sentiam em mim.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/03-apartment-odor-insider/hero.jpg"
    },
    "04-gas-at-dinner-contradiction": {
      "headline": "Achei que trocar a ração ia resolver os gases. Só piorou a vergonha",
      "lead": "Achei que trocar a ração ia resolver os gases do meu cachorro. Só piorou a vergonha. O Zeca é um Bulldog. Soltava uns gases tão fortes que limpavam a sala.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/04-gas-at-dinner-contradiction/hero.jpg"
    },
    "05-scooting-carpet-check-stat": {
      "headline": "Eu checava o tapete toda vez antes de abrir a porta pra alguém",
      "lead": "Contei uma vez: foram dezenove vezes num mês. Dezenove vezes me abaixando pra ver se tinha marca de bumbum arrastado no tapete. A Bel, minha Shih Tzu, arrastava o bumbum pelo chão. Deixava rastro. E quando lambia, soltava um cheiro ruim.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/05-scooting-carpet-check-stat/hero.jpg"
    },
    "01-sensitive-gut-senior-night": {
      "headline": "Minha mãe me ligou às duas da manhã por causa da cachorra",
      "lead": "\"A Nina não para de se mexer. Acha que é a barriga de novo?\" Eu sabia que era. Nem precisava olhar o relógio. De novo. Tenho cinquenta e dois anos. Moro sozinha com a Nina desde que meu pai faleceu. Minha mãe mora a quinze minutos.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/01-sensitive-gut-senior-night/hero.jpg"
    },
    "02-husband-tired-night": {
      "headline": "Não era só o cachorro que estava cansado. Era o meu casamento",
      "lead": "Tenho trinta e seis anos. Moro em São Paulo com meu marido Rafael. E o Pingo. Schnauzer de seis anos. Dez quilos. Docil. Engraçado. Quando a barriga dele está bem. Quando não está... Acorda a casa toda. Antes do Pingo, Rafael e eu dormíamos oito horas.",
      "hero": "https://artigos.mimiepipo.com.br/creatives/02-husband-tired-night/hero.jpg"
    },
    "03-daughter-said-discovery": {
      "headline": "A minha filha de seis anos disse uma coisa que me fez agir",
      "lead": "A Lua, nossa Maltês, sempre dormiu grudada nela. Mas a Lua andava com gases fortes e um cheiro ruim. A barriga vivia roncando. Um dia, a Lua subiu no sofá pra deitar do lado da minha filha. E a minha filha empurrou de leve e falou: \"Mãe, a Lua tá fedida. Não quero ela perto agora.\"",
      "hero": "https://artigos.mimiepipo.com.br/creatives/03-daughter-said-discovery/hero.jpg"
    },
    "04-itching-keeps-us-awake-contradiction": {
